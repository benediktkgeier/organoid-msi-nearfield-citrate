# --- Large data / binary ---
# all RDS + imzML intermediates
cache/
# On-tissue-ion candidate-sheet upload artifacts (per-sample image dirs, ~1.4 GB).
# Regenerable from cache/peaks_combined.rds via the phase-03 export script.
results/peakme/
# regenerable; depends on cache/imzml/
results/imzml_probe.csv
# regen run logs
results/_regen_logs/

# --- Large figures / rendered outputs (regenerable from cache/*.rds; ship code, not outputs) ---
# Figure images (PDF + raster) are regenerated by the pipeline / run_all.sh and are
# part of the data deposit, not the code repo. This includes the native BF / IF
# crop PNGs under figures/**/crops/ that the reports consume (regenerated by Phases 05/06).
figures/**/*.pdf
figures/**/*.png
figures/**/*.jpg
figures/**/*.jpeg
figures/**/*.tif
figures/**/*.tiff
Rplots.pdf

# Keep small QC/diagnostic PDFs by un-ignoring them here if you want them tracked:
# !figures/preprocess/qc_combined.pdf
# !figures/preprocess/feature_filter_diagnostic.pdf

# --- Bruker raw data (never commit) ---
*.d/
*.tdf
*.tdf_bin
*.tsf
*.tsf_bin

# --- imzML / ibd ---
*.imzML
*.ibd
*.imzML.tmp
*.ibd.tmp

# --- Microscopy raw ---
*.nd2
*.nd2.lock
*.czi
*.lif
# SCiLS / FlexImaging thumbnails
*_small_*.jpg

